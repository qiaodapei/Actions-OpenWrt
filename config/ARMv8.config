#
# OpenWrt .config
#

# --------------------------------------------------
# 基本设置
# --------------------------------------------------
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y

# --------------------------------------------------
# 目标架构及设备
# --------------------------------------------------
CONFIG_TARGET_armvirt=y
CONFIG_TARGET_armvirt_64=y
CONFIG_TARGET_armvirt_64_DEVICE_generic=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_BOARD="armvirt"
CONFIG_TARGET_SUBTARGET="64"
CONFIG_TARGET_PROFILE="DEVICE_generic"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe"
CONFIG_CPU_TYPE="cortex-a53"

# --------------------------------------------------
# 内核配置
# --------------------------------------------------
CONFIG_LINUX_6_6=y

# --------------------------------------------------
# 默认软件包选择（核心部分）
# --------------------------------------------------
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_default-settings=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_firewall=y
CONFIG_DEFAULT_opkg=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_procd=y
CONFIG_DEFAULT_uci=y

# 网络相关工具
CONFIG_DEFAULT_ip-full=y
CONFIG_DEFAULT_iptables=y
CONFIG_DEFAULT_ip6tables=y
CONFIG_DEFAULT_ipset=y
CONFIG_DEFAULT_dnsmasq-full=y
CONFIG_DEFAULT_dropbear=y
CONFIG_DEFAULT_autocore-arm=y
CONFIG_DEFAULT_autosamba=y

# 插件：磁盘管理
CONFIG_PACKAGE_luci-app-diskman=y

# 插件：Argon 主题
CONFIG_PACKAGE_luci-app-argon-config=y

# 插件：网络向导
CONFIG_PACKAGE_luci-app-quickstart=y

# 插件：易有云
CONFIG_PACKAGE_luci-app-linkease=y

# 插件：OpenClash 代理
CONFIG_PACKAGE_luci-app-openclash=y

# 插件：统一文件共享
CONFIG_PACKAGE_luci-app-unishare=y

# 插件：NFS 管理
CONFIG_PACKAGE_luci-app-nfs=y

# 插件：S.M.A.R.T. 硬盘监控
CONFIG_PACKAGE_luci-app-smartd=y

# 插件：挂载网络共享
CONFIG_PACKAGE_luci-app-cifs-mount=y

# 插件: 终端访问
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_libjson-c=y
CONFIG_PACKAGE_libwebsockets=y
CONFIG_PACKAGE_libncurses=y

# 插件: CPU 频率调节
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_cpufreq-utils=y

# 插件: IPK 镜像服务器
CONFIG_PACKAGE_luci-app-ipkg-mirror=y
CONFIG_PACKAGE_uhttpd=y

# 插件: Samba 文件共享
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y

# 插件: 启动管理
CONFIG_PACKAGE_luci-app-startup=y

# 插件: 沙箱功能
CONFIG_PACKAGE_luci-app-sandbox=y

# --------------------------------------------------
# 硬件驱动
# --------------------------------------------------

# 无线网卡驱动（N1 内置无线）
CONFIG_PACKAGE_kmod-brcmfmac=y   # 适用于 斐讯 N1 的无线网卡驱动

# USB 驱动
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-hid=y
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_kmod-usb-audio=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-pl2303=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-asix=y

# eMMC 存储支持（N1 内置存储）
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-spi=y
CONFIG_PACKAGE_kmod-mmc-block=y

# 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-xfs=y
CONFIG_PACKAGE_kmod-fs-fuse=y

# --------------------------------------------------
# IPv6 支持
# --------------------------------------------------
CONFIG_KERNEL_IPV6=y
CONFIG_KERNEL_IPV6_MULTIPLE_TABLES=y
CONFIG_KERNEL_IPV6_MROUTE=y

# --------------------------------------------------
# 安全加固选项
# --------------------------------------------------
CONFIG_SECCOMP=y
CONFIG_KERNEL_CC_STACKPROTECTOR_REGULAR=y
CONFIG_PKG_CC_STACKPROTECTOR_REGULAR=y
CONFIG_PKG_FORTIFY_SOURCE_1=y
CONFIG_PKG_RELRO_FULL=y

# --------------------------------------------------
# 文件系统及镜像设置（适配 N1）
# --------------------------------------------------
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_RESERVED_PCT=0
CONFIG_TARGET_EXT4_BLOCKSIZE_4K=y
CONFIG_TARGET_EXT4_BLOCKSIZE=4096
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256

# eMMC/USB 镜像支持
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=16
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# --------------------------------------------------
# 调试工具（仅供开发使用）
# --------------------------------------------------
CONFIG_PACKAGE_kmod-usb-debug=y
CONFIG_PACKAGE_kmod-phy-bcm-ns2=y
CONFIG_KERNEL_PRINTK=y
CONFIG_KERNEL_DEBUG_FS=y
CONFIG_KERNEL_DEBUG_KERNEL=y
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_REDUCED=y
CONFIG_KERNEL_FRAME_WARN=2048
CONFIG_KERNEL_AIO=y
CONFIG_KERNEL_IO_URING=y
CONFIG_KERNEL_FHANDLE=y
