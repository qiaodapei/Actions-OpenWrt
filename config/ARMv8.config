# ---------- Target & Device Configuration ----------
CONFIG_TARGET_armvirt=y                              # 目标平台：armvirt 虚拟平台
CONFIG_TARGET_armvirt_64=y                           # 64位armvirt支持
CONFIG_TARGET_armvirt_64_DEVICE_generic=y            # 通用设备配置

# ---------- BATMAN-ADV Networking Options ----------
CONFIG_BATMAN_ADV_BATMAN_V=y                         # 启用BATMAN-ADV V版本
CONFIG_BATMAN_ADV_BLA=y                              # 启用BATMAN-ADV BLA选项 【可精简：多个BATMAN_ADV选项可合并管理】
CONFIG_BATMAN_ADV_DAT=y                              # 启用BATMAN-ADV DAT选项 【可精简】
CONFIG_BATMAN_ADV_MCAST=y                            # 启用BATMAN-ADV组播支持 【可精简】

# ---------- BRCMFMAC Interface Options ----------
CONFIG_BRCMFMAC_PCIE=y                               # Broadcom PCIe接口支持
CONFIG_BRCMFMAC_SDIO=y                               # Broadcom SDIO接口支持
CONFIG_BRCMFMAC_USB=y                                # Broadcom USB接口支持

# ---------- Filesystem Tools ----------
CONFIG_BTRFS_PROGS_ZSTD=y                            # Btrfs工具启用ZSTD压缩支持

# ---------- CGroups Configuration ----------
CONFIG_CGROUPFS_MOUNT_KERNEL_CGROUPS=y               # 通过cgroupfs挂载内核cgroup

# ---------- Docker Configuration Options ----------
CONFIG_DOCKER_CGROUP_OPTIONS=y                       # Docker cgroup选项
CONFIG_DOCKER_NET_MACVLAN=y                          # Docker MACVLAN网络支持
CONFIG_DOCKER_OPTIONAL_FEATURES=y                    # Docker附加功能
CONFIG_DOCKER_STO_EXT4=y                             # Docker存储使用EXT4

# ---------- Wireless Driver & Kernel Features ----------
CONFIG_DRIVER_11AC_SUPPORT=y                         # 启用11AC无线驱动支持
CONFIG_KERNEL_ARM_PMU=y                              # ARM性能监控单元支持
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y                    # CFQ分组IOSCHED调度器

# ---------- Kernel CGroups & Memory Management ----------
CONFIG_KERNEL_CGROUP_DEVICE=y                        # 内核cgroup设备支持
CONFIG_KERNEL_CGROUP_FREEZER=y                       # 内核cgroup冻结支持
CONFIG_KERNEL_CGROUP_HUGETLB=y                       # 内核cgroup大页支持
CONFIG_KERNEL_CGROUP_NET_PRIO=y                      # 内核cgroup网络优先级支持
CONFIG_KERNEL_CGROUP_PERF=y                          # 内核cgroup性能计数支持
CONFIG_KERNEL_HUGETLBFS=y                            # 大页文件系统支持
CONFIG_KERNEL_HUGETLB_PAGE=y                         # 内核大页支持
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=y                   # 内存cgroup交换支持
CONFIG_KERNEL_NET_CLS_CGROUP=y                       # 网络流量分类cgroup支持
CONFIG_KERNEL_PERF_EVENTS=y                          # 内核性能事件支持
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y                # 启用透明大页
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y         # 始终启用透明大页

# ---------- MBEDTLS Crypto Library Options ----------
CONFIG_MBEDTLS_AES_C=y                               # 启用AES加密支持
CONFIG_MBEDTLS_CMAC_C=y                              # 启用CMAC支持
CONFIG_MBEDTLS_DES_C=y                               # 启用DES加密支持
CONFIG_MBEDTLS_ECP_DP_CURVE25519_ENABLED=y           # 启用Curve25519椭圆曲线支持 【可精简：多个曲线支持项可合并标注】
CONFIG_MBEDTLS_ECP_DP_SECP256K1_ENABLED=y              # 启用secp256k1椭圆曲线支持 【可精简】
CONFIG_MBEDTLS_ECP_DP_SECP256R1_ENABLED=y              # 启用secp256r1椭圆曲线支持 【可精简】
CONFIG_MBEDTLS_ECP_DP_SECP384R1_ENABLED=y              # 启用secp384r1椭圆曲线支持 【可精简】
CONFIG_MBEDTLS_ENTROPY_FORCE_SHA256=y                # 强制使用SHA256作为熵源
CONFIG_MBEDTLS_GCM_C=y                               # 启用GCM模式
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED=y      # 启用ECDHE_ECDSA密钥交换
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_PSK_ENABLED=y        # 启用ECDHE_PSK密钥交换
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_RSA_ENABLED=y        # 启用ECDHE_RSA密钥交换
CONFIG_MBEDTLS_KEY_EXCHANGE_PSK_ENABLED=y            # 启用PSK密钥交换
CONFIG_MBEDTLS_NIST_KW_C=y                           # 启用NIST关键字包装
CONFIG_MBEDTLS_RSA_NO_CRT=y                           # 禁用RSA CRT优化

# ---------- NodeJS Configuration ----------
# CONFIG_NODEJS_20 is not set                         # NodeJS 20未启用
CONFIG_NODEJS_22=y                                   # 启用NodeJS 22

# ---------- OpenSSH Options ----------
CONFIG_OPENSSH_LIBFIDO2=y                            # 启用OpenSSH的libfido2支持

# ---------- Package Selections ----------

# [Network Tunneling & Wireless Debug]
CONFIG_PACKAGE_6in4=y                                # 6in4隧道支持，用于IPv6 over IPv4
CONFIG_PACKAGE_MAC80211_DEBUGFS=y                    # mac80211调试文件系统支持
CONFIG_PACKAGE_MAC80211_MESH=y                       # mac80211网状网络支持

# [Archive and Compression Tools] 【可精简：多种tar格式可整合】
CONFIG_PACKAGE_TAR_BZIP2=y                           # TAR工具，支持BZIP2压缩 【可精简】
CONFIG_PACKAGE_TAR_GZIP=y                            # TAR工具，支持GZIP压缩 【可精简】
CONFIG_PACKAGE_TAR_POSIX_ACL=y                       # TAR工具，支持POSIX ACL 【可精简】
CONFIG_PACKAGE_TAR_XATTR=y                           # TAR工具，支持扩展属性 【可精简】
CONFIG_PACKAGE_TAR_XZ=y                              # TAR工具，支持XZ压缩 【可精简】
CONFIG_PACKAGE_TAR_ZSTD=y                            # TAR工具，支持ZSTD压缩 【可精简】

# [Cloud Storage & WebDAV]
CONFIG_PACKAGE_aliyundrive-webdav=y                 # AliyunDrive WebDAV客户端

# [Core Utilities & Shell]
CONFIG_PACKAGE_attr=y                                # 文件属性操作工具
CONFIG_PACKAGE_bash=y                                # Bash Shell

# [BATMAN Control & Block Device Tools]
CONFIG_PACKAGE_batctl-default=y                      # BATMAN-ADV控制工具 【可精简：可与其它BATMAN工具合并】
CONFIG_PACKAGE_blkid=y                               # blkid工具，用于识别块设备

# [Boost Libraries] 【可精简：多个Boost模块可合并配置】
CONFIG_PACKAGE_boost=y                               # Boost库集合
CONFIG_PACKAGE_boost-program_options=y               # Boost命令行参数解析库 【可精简】
CONFIG_PACKAGE_boost-system=y                        # Boost系统库 【可精简】

# [Firmware & Archive Tools]
CONFIG_PACKAGE_brcmfmac-firmware-usb=y               # brcmfmac USB固件
CONFIG_PACKAGE_bsdtar=y                              # BSD Tar归档工具
CONFIG_PACKAGE_btrfs-progs=y                         # Btrfs文件系统工具

# [Compression Utilities]
CONFIG_PACKAGE_bzip2=y                              # Bzip2压缩工具

# [CGroup Filesystem Mount]
CONFIG_PACKAGE_cgroupfs-mount=y                      # 挂载cgroup文件系统

# [File Attribute Management]
CONFIG_PACKAGE_chattr=y                              # 修改文件属性工具

# [DNS & Network Utilities]
CONFIG_PACKAGE_chinadns-ng=y                         # Chinadns-ng，用于DNS解析
CONFIG_PACKAGE_containerd=y                          # Containerd容器运行时
CONFIG_PACKAGE_dawn=y                                # Dawn工具（用途待确认，可能为网络相关工具）

# [Docker Ecosystem]
CONFIG_PACKAGE_docker=y                              # Docker容器引擎
CONFIG_PACKAGE_docker-compose=y                      # Docker Compose工具
CONFIG_PACKAGE_dockerd=y                             # Docker守护进程

# [Disk & Filesystem Utilities]
CONFIG_PACKAGE_dosfstools=y                          # DOS文件系统工具
CONFIG_PACKAGE_f2fs-tools=y                          # F2FS文件系统工具
CONFIG_PACKAGE_f2fsck=y                              # F2FS文件系统检测工具
CONFIG_PACKAGE_fdisk=y                               # fdisk分区工具

# [Text Processing & Miscellaneous]
CONFIG_PACKAGE_gawk=y                                # GNU awk文本处理工具
CONFIG_PACKAGE_geoview=y                             # GeoView工具（可能用于网络拓扑展示）
CONFIG_PACKAGE_getopt=y                              # 命令行参数解析工具

# [Load Balancing & Wireless AP]
CONFIG_PACKAGE_haproxy=y                             # HAProxy负载均衡器
CONFIG_PACKAGE_hostapd-common=y                      # hostapd通用组件

# [Proxy & iptables Extensions] 【可精简：iptables扩展项可整合】
CONFIG_PACKAGE_ipt2socks=y                           # 将IP流量重定向到SOCKS代理
CONFIG_PACKAGE_iptables-mod-iprange=y                # iptables IP范围匹配模块 【可精简】
CONFIG_PACKAGE_iptables-mod-socket=y                 # iptables套接字匹配模块 【可精简】
CONFIG_PACKAGE_ipv6helper=y                          # IPv6辅助工具

# [Wireless Configuration Tools]
CONFIG_PACKAGE_iw=y                                  # 无线配置工具iw
CONFIG_PACKAGE_iwinfo=y                              # 无线信息查询工具iwinfo

# ---------- Kernel Module Packages ----------
CONFIG_PACKAGE_kmod-asn1-encoder=y                   # ASN1编码内核模块
CONFIG_PACKAGE_kmod-batman-adv=y                     # BATMAN-ADV内核模块
CONFIG_PACKAGE_kmod-br-netfilter=y                   # 桥接网络过滤内核模块
CONFIG_PACKAGE_kmod-brcmfmac=y                       # Broadcom无线内核模块
CONFIG_PACKAGE_kmod-brcmutil=y                       # Broadcom实用工具内核模块
CONFIG_PACKAGE_kmod-cfg80211=y                       # cfg80211无线配置内核模块
CONFIG_PACKAGE_kmod-crypto-acompress=y               # 加密压缩内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-cbc=y                      # CBC加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-ccm=y                      # CCM加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-cmac=y                     # CMAC加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-crc32c=y                   # CRC32C内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-ctr=y                      # CTR加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-gcm=y                      # GCM加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-gf128=y                    # GF128算法内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-ghash=y                    # GHASH内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-hmac=y                     # HMAC内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-kpp=y                      # KPP内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y             # Chacha20加密库内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y       # Chacha20-Poly1305加密库 【可精简】
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y           # Curve25519加密库内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y             # Poly1305加密库内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-rng=y                      # 加密随机数生成内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-seqiv=y                    # SEQIV加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-sha256=y                   # SHA256加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-crypto-sha512=y                   # SHA512加密内核模块 【可精简】
CONFIG_PACKAGE_kmod-dax=y                             # DAX支持内核模块
CONFIG_PACKAGE_kmod-dm=y                              # 设备映射内核模块
CONFIG_PACKAGE_kmod-dummy=y                           # Dummy网卡内核模块
CONFIG_PACKAGE_kmod-fs-btrfs=y                        # Btrfs文件系统内核模块
CONFIG_PACKAGE_kmod-ikconfig=y                        # 内核配置提取模块
CONFIG_PACKAGE_kmod-inet-diag=y                       # 网络诊断内核模块
CONFIG_PACKAGE_kmod-ipt-iprange=y                     # ipt iprange内核模块 【可精简】
CONFIG_PACKAGE_kmod-ipt-physdev=y                     # ipt physdev内核模块 【可精简】
CONFIG_PACKAGE_kmod-ipt-socket=y                      # ipt socket内核模块 【可精简】
CONFIG_PACKAGE_kmod-iptunnel=y                        # iptunnel内核模块 【可精简：可与iptunnel4合并】
CONFIG_PACKAGE_kmod-iptunnel4=y                       # iptunnel4内核模块 【可精简】
CONFIG_PACKAGE_kmod-keys-encrypted=y                  # 加密密钥内核模块 【可精简】
CONFIG_PACKAGE_kmod-keys-trusted=y                    # 信任密钥内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-crc16=y                       # CRC16库内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-crc32c=y                      # CRC32C库内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-lzo=y                         # LZO压缩库内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-raid6=y                       # RAID6支持内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-xor=y                         # XOR运算内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-zlib-deflate=y                # zlib压缩(deflate)内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-zlib-inflate=y                # zlib解压内核模块 【可精简】
CONFIG_PACKAGE_kmod-lib-zstd=y                        # zstd压缩内核模块 【可精简】
CONFIG_PACKAGE_kmod-mac80211=y                        # mac80211无线内核模块
CONFIG_PACKAGE_kmod-md-mod=y                          # MD模块支持
CONFIG_PACKAGE_kmod-md-raid0=y                        # RAID0支持内核模块 【可精简】
CONFIG_PACKAGE_kmod-md-raid1=y                        # RAID1支持内核模块 【可精简】
CONFIG_PACKAGE_kmod-md-raid10=y                       # RAID10支持内核模块 【可精简】
CONFIG_PACKAGE_kmod-mmc=y                             # MMC卡支持内核模块
CONFIG_PACKAGE_kmod-netlink-diag=y                    # Netlink诊断内核模块
CONFIG_PACKAGE_kmod-nf-ipvs=y                         # IPVS内核模块
CONFIG_PACKAGE_kmod-nf-socket=y                       # Netfilter socket内核模块 【可精简】
CONFIG_PACKAGE_kmod-oid-registry=y                    # OID注册内核模块 【可精简】
CONFIG_PACKAGE_kmod-random-core=y                     # 随机数生成核心模块 【可精简】
CONFIG_PACKAGE_kmod-sit=y                             # SIT隧道支持内核模块 【可精简】
CONFIG_PACKAGE_kmod-tpm=y                             # TPM支持内核模块
CONFIG_PACKAGE_kmod-udptunnel4=y                      # UDP隧道4内核模块 【可精简】
CONFIG_PACKAGE_kmod-udptunnel6=y                      # UDP隧道6内核模块 【可精简】
CONFIG_PACKAGE_kmod-usb-core=y                        # USB核心内核模块
CONFIG_PACKAGE_kmod-veth=y                            # 虚拟以太网内核模块
CONFIG_PACKAGE_kmod-wireguard=y                       # WireGuard内核模块

# ---------- Libraries ----------
CONFIG_PACKAGE_libacl=y                              # ACL库
CONFIG_PACKAGE_libarchive=y                          # 归档库
