# ---------- Perl & Perl Base Modules ---------- 【可精简：Perl模块可以合并配置】
CONFIG_PACKAGE_perl=y                                # Perl解释器
CONFIG_PACKAGE_perl-http-date=y                      # Perl HTTP日期模块
CONFIG_PACKAGE_perlbase-base=y                       # Perl基础模块
CONFIG_PACKAGE_perlbase-bytes=y                      # Perl字节处理模块
CONFIG_PACKAGE_perlbase-charnames=y                  # Perl字符名模块
CONFIG_PACKAGE_perlbase-class=y                      # Perl类模块
CONFIG_PACKAGE_perlbase-config=y                     # Perl配置模块
CONFIG_PACKAGE_perlbase-cwd=y                        # Perl当前工作目录模块
CONFIG_PACKAGE_perlbase-dynaloader=y                 # Perl动态加载模块
CONFIG_PACKAGE_perlbase-errno=y                      # Perl错误号模块
CONFIG_PACKAGE_perlbase-essential=y                  # Perl核心模块
CONFIG_PACKAGE_perlbase-fcntl=y                      # Perl文件控制模块
CONFIG_PACKAGE_perlbase-file=y                       # Perl文件操作模块
CONFIG_PACKAGE_perlbase-filehandle=y                 # Perl文件句柄模块
CONFIG_PACKAGE_perlbase-getopt=y                     # Perl命令行选项解析模块
CONFIG_PACKAGE_perlbase-i18n=y                       # Perl国际化模块
CONFIG_PACKAGE_perlbase-integer=y                    # Perl整数处理模块
CONFIG_PACKAGE_perlbase-io=y                         # Perl I/O模块
CONFIG_PACKAGE_perlbase-list=y                       # Perl列表处理模块
CONFIG_PACKAGE_perlbase-locale=y                     # Perl本地化模块
CONFIG_PACKAGE_perlbase-params=y                     # Perl参数处理模块
CONFIG_PACKAGE_perlbase-posix=y                      # Perl POSIX模块
CONFIG_PACKAGE_perlbase-re=y                         # Perl正则表达式模块
CONFIG_PACKAGE_perlbase-scalar=y                     # Perl标量模块
CONFIG_PACKAGE_perlbase-selectsaver=y                # Perl选择保存模块
CONFIG_PACKAGE_perlbase-socket=y                     # Perl套接字模块
CONFIG_PACKAGE_perlbase-symbol=y                     # Perl符号模块
CONFIG_PACKAGE_perlbase-tie=y                        # Perl绑定模块
CONFIG_PACKAGE_perlbase-time=y                       # Perl时间模块
CONFIG_PACKAGE_perlbase-unicode=y                    # PerlUnicode支持
CONFIG_PACKAGE_perlbase-unicore=y                    # Perl Unicore模块
CONFIG_PACKAGE_perlbase-utf8=y                       # Perl UTF-8支持
CONFIG_PACKAGE_perlbase-xsloader=y                   # Perl XS加载器

# ---------- Miscellaneous Utilities ----------
CONFIG_PACKAGE_pigz=y                                # 并行gzip工具
CONFIG_PACKAGE_pv=y                                  # pv流量监控工具
CONFIG_PACKAGE_quickstart=y                          # 快速启动工具

# ---------- Ruby & Ruby Modules ----------
CONFIG_PACKAGE_ruby=y                                # Ruby解释器
CONFIG_PACKAGE_ruby-bigdecimal=y                     # Ruby大数模块
CONFIG_PACKAGE_ruby-date=y                           # Ruby日期模块
CONFIG_PACKAGE_ruby-digest=y                         # Ruby摘要模块
CONFIG_PACKAGE_ruby-enc=y                            # Ruby编码模块
CONFIG_PACKAGE_ruby-forwardable=y                    # Ruby转发模块
CONFIG_PACKAGE_ruby-pstore=y                         # Ruby持久存储模块
CONFIG_PACKAGE_ruby-psych=y                          # Ruby YAML解析器
CONFIG_PACKAGE_ruby-stringio=y                       # Ruby字符串IO模块
CONFIG_PACKAGE_ruby-strscan=y                        # Ruby字符串扫描模块
CONFIG_PACKAGE_ruby-yaml=y                           # Ruby YAML模块

# ---------- Container Runtime & Script Utilities ----------
CONFIG_PACKAGE_runc=y                                # runc容器运行时
CONFIG_PACKAGE_script-utils=y                        # 脚本工具

# ---------- Shadow (用户与组管理) ----------
CONFIG_PACKAGE_shadow=y                              # Shadow工具集
CONFIG_PACKAGE_shadow-chage=y                        # 修改密码过期信息工具 【可精简】
CONFIG_PACKAGE_shadow-chfn=y                         # 修改用户全名工具 【可精简】
CONFIG_PACKAGE_shadow-chgpasswd=y                    # 修改密码工具 【可精简】
CONFIG_PACKAGE_shadow-chpasswd=y                     # 修改密码工具 【可精简】
CONFIG_PACKAGE_shadow-chsh=y                         # 修改登录Shell工具 【可精简】
CONFIG_PACKAGE_shadow-common=y                       # Shadow公共工具 【可精简】
CONFIG_PACKAGE_shadow-expiry=y                       # 用户过期管理工具 【可精简】
CONFIG_PACKAGE_shadow-faillog=y                      # 登录失败日志工具 【可精简】
CONFIG_PACKAGE_shadow-gpasswd=y                      # 修改组密码工具 【可精简】
CONFIG_PACKAGE_shadow-groupadd=y                     # 添加用户组工具 【可精简】
CONFIG_PACKAGE_shadow-groupdel=y                     # 删除用户组工具 【可精简】
CONFIG_PACKAGE_shadow-groupmems=y                    # 用户组成员管理 【可精简】
CONFIG_PACKAGE_shadow-groupmod=y                     # 修改用户组工具 【可精简】
CONFIG_PACKAGE_shadow-groups=y                       # 用户组管理 【可精简】
CONFIG_PACKAGE_shadow-grpck=y                        # 检查组文件工具 【可精简】
CONFIG_PACKAGE_shadow-grpconv=y                      # 转换组文件工具 【可精简】
CONFIG_PACKAGE_shadow-grpunconv=y                    # 反转换组文件工具 【可精简】
CONFIG_PACKAGE_shadow-lastlog=y                      # 查看最后登录记录 【可精简】
CONFIG_PACKAGE_shadow-login=y                        # 用户登录工具 【可精简】
CONFIG_PACKAGE_shadow-logoutd=y                      # 用户注销守护进程 【可精简】
CONFIG_PACKAGE_shadow-newgidmap=y                    # 新组ID映射工具 【可精简】
CONFIG_PACKAGE_shadow-newgrp=y                       # 切换用户组工具 【可精简】
CONFIG_PACKAGE_shadow-newuidmap=y                    # 新用户ID映射工具 【可精简】
CONFIG_PACKAGE_shadow-newusers=y                     # 添加新用户工具 【可精简】
CONFIG_PACKAGE_shadow-nologin=y                      # 禁止登录工具 【可精简】
CONFIG_PACKAGE_shadow-passwd=y                       # 修改用户密码工具 【可精简】
CONFIG_PACKAGE_shadow-pwck=y                         # 检查密码文件工具 【可精简】
CONFIG_PACKAGE_shadow-pwconv=y                       # 转换密码文件工具 【可精简】
CONFIG_PACKAGE_shadow-pwunconv=y                     # 反转换密码文件工具 【可精简】
CONFIG_PACKAGE_shadow-su=y                           # 切换用户工具 【可精简】
CONFIG_PACKAGE_shadow-useradd=y                      # 添加用户工具 【可精简】
CONFIG_PACKAGE_shadow-userdel=y                      # 删除用户工具 【可精简】
CONFIG_PACKAGE_shadow-usermod=y                      # 修改用户工具 【可精简】
CONFIG_PACKAGE_shadow-utils=y                        # Shadow实用工具集 【可精简】
CONFIG_PACKAGE_shadow-vipw=y                         # 编辑密码文件工具 【可精简】
CONFIG_shadow-all=y                                  # 启用所有Shadow工具 【可精简：可用shadow-all代替单独配置】

# ---------- Shadowsocks-libev Components ----------
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y           # Shadowsocks-libev本地代理 【可精简】
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y           # Shadowsocks-libev重定向代理 【可精简】
CONFIG_PACKAGE_shadowsocks-libev-ss-server=y          # Shadowsocks-libev服务端 【可精简】

# ---------- Sing-Box & 相关工具 ----------
CONFIG_PACKAGE_sing-box=y                            # Sing-Box工具

# ---------- SMART Disk Monitoring ----------
CONFIG_PACKAGE_smartd=y                              # SMART磁盘监控守护进程
CONFIG_PACKAGE_smartmontools=y                       # SMART磁盘工具

# ---------- Tar Utility (独立tar工具) 【可精简：与上面tar工具重复】 
CONFIG_PACKAGE_tar=y                                 # Tar归档工具

# ---------- Task Management ----------
CONFIG_PACKAGE_taskd=y                               # Taskd任务调度工具

# ---------- Terminal Information ----------
CONFIG_PACKAGE_terminfo=y                            # Terminfo终端信息库

# ---------- Minimal Init Process ----------
CONFIG_PACKAGE_tini=y                                # Tini微型init进程

# ---------- Trojan & VPN Tools ----------
CONFIG_PACKAGE_trojan-plus=y                         # Trojan Plus VPN工具

# ---------- TTY Daemon ----------
CONFIG_PACKAGE_ttyd=y                                # ttyd Web终端工具

# ---------- Ucode Modules ----------
CONFIG_PACKAGE_ucode-mod-nl80211=y                   # nl80211 ucode模块
CONFIG_PACKAGE_ucode-mod-rtnl=y                      # rtnl ucode模块
CONFIG_PACKAGE_ucode-mod-uloop=y                     # uloop ucode模块

# ---------- DNS & Compression Utilities ----------
CONFIG_PACKAGE_umdns=y                               # Umdns DNS工具
CONFIG_PACKAGE_unzip=y                               # Unzip解压工具
CONFIG_PACKAGE_uuidgen=y                             # UUID生成工具

# ---------- V2Ray Plugin ----------
CONFIG_PACKAGE_v2ray-plugin=y                        # V2Ray插件

# ---------- WireGuard Tools ----------
CONFIG_PACKAGE_wireguard-tools=y                     # WireGuard工具

# ---------- Wireless Regulatory Database ----------
CONFIG_PACKAGE_wireless-regdb=y                      # 无线监管数据库

# ---------- WPA Command Line Tools ----------
CONFIG_PACKAGE_wpa-cli=y                             # WPA命令行工具
CONFIG_PACKAGE_wpad-basic=m                          # 基础wpad包 (模块形式)
CONFIG_PACKAGE_wpad-mesh-openssl=y                   # Mesh模式wpad，基于OpenSSL

# ---------- XFS Filesystem Tools ----------
CONFIG_PACKAGE_xfs-fsck=y                            # XFS文件系统检查工具
CONFIG_PACKAGE_xfs-mkfs=y                            # XFS文件系统创建工具

# ---------- XZ Compression Tools 【可精简：xz与xz-utils可合并】 
CONFIG_PACKAGE_xz=y                                  # XZ压缩工具
CONFIG_PACKAGE_xz-utils=y                            # XZ工具集

# ---------- Miscellaneous Build/Script Options ----------
CONFIG_PARTED_READLINE=y                             # 使用readline支持的parted 【可精简】
CONFIG_PERL_NOCOMMENT=y                              # Perl解析时忽略注释 【可精简】
CONFIG_PERL_THREADS=y                                # 启用Perl多线程支持 【可精简】

# ---------- Sing-Box 扩展选项 ----------
CONFIG_SING_BOX_WITH_CLASH_API=y                     # Sing-Box支持Clash API
CONFIG_SING_BOX_WITH_DHCP=y                          # Sing-Box内置DHCP支持
CONFIG_SING_BOX_WITH_ECH=y                           # Sing-Box支持ECH（Encrypted ClientHello）
CONFIG_SING_BOX_WITH_GVISOR=y                        # Sing-Box集成gVisor支持
CONFIG_SING_BOX_WITH_QUIC=y                          # Sing-Box支持QUIC协议
CONFIG_SING_BOX_WITH_UTLS=y                          # Sing-Box支持UTLS
CONFIG_SING_BOX_WITH_WIREGUARD=y                     # Sing-Box支持WireGuard

# ---------- Target RootFS & Miscellaneous Settings ----------
CONFIG_TARGET_ROOTFS_PARTSIZE=1024                 # 根文件系统分区大小（单位：MB）
CONFIG_WPA_MSG_MIN_PRIORITY=3                        # WPA消息最低优先级
CONFIG_ZSTD_OPTIMIZE_O3=y                            # ZSTD优化编译选项O3

# ---------- Boost Build Options (编译选项) 【可精简：各Boost选项可统一配置】 
CONFIG_boost-compile-visibility-hidden=y           # Boost编译时隐藏符号
CONFIG_boost-runtime-shared=y                        # Boost运行时使用共享库
CONFIG_boost-static-and-shared-libs=y                # Boost同时构建静态和共享库
CONFIG_boost-variant-release=y                       # Boost发布版本设置

# ---------- Additional Kernel Modules & Network Enhancements ----------
CONFIG_PACKAGE_kmod-ipt-offload=y                    # ipt-offload内核模块 【可精简】
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y            # NF conntrack netlink模块 【可精简】
CONFIG_PACKAGE_kmod-nf-flow=y                         # NF flow模块 【可精简】
CONFIG_PACKAGE_kmod-tcp-bbr=y                         # TCP BBR拥塞控制内核模块
CONFIG_PACKAGE_nlbwmon=y                             # Nlbwmon流量监控工具
CONFIG_PACKAGE_vlmcsd=y                              # Vlmcsd激活服务器工具
CONFIG_PACKAGE_vsftpd-alt=y                          # vsftpd替代版 【可精简】
CONFIG_VSFTPD_USE_UCI_SCRIPTS=y                      # vsftpd使用UCI脚本配置
