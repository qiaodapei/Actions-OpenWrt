#
# OpenWrt .config (斐讯 N1 版)
#

# --------------------------------------------------
# 基本设置
# --------------------------------------------------
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y

# --------------------------------------------------
# 目标架构及设备 - 斐讯 N1
# --------------------------------------------------
CONFIG_TARGET_armvirt=y
# 斐讯 N1 设备选项（需确保 OpenWrt 源码中已添加对 phicomm_n1 的支持）
CONFIG_TARGET_armvirt_DEVICE_phicomm_n1=y
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe"

# --------------------------------------------------
# 内核配置
# --------------------------------------------------
CONFIG_LINUX_6_6=y

# --------------------------------------------------
# 默认软件包选择（核心部分）
# --------------------------------------------------
# 系统基础
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_default-settings=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_firewall=y
CONFIG_DEFAULT_opkg=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_procd=y
CONFIG_DEFAULT_uci=y

# 网络及相关工具
CONFIG_DEFAULT_ip-full=y
CONFIG_DEFAULT_iptables=y
CONFIG_DEFAULT_ip6tables=y
CONFIG_DEFAULT_ipset=y
# 移除 x86 专用优化，保留自动挂载、自动 Samba 等插件
# CONFIG_DEFAULT_autocore-x86 已移除
CONFIG_DEFAULT_automount=y
CONFIG_DEFAULT_autosamba=y
CONFIG_DEFAULT_dnsmasq-full=y
CONFIG_DEFAULT_dropbear=y

# 插件：磁盘管理
CONFIG_DEFAULT_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_btrfs-progs=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_lsblk=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_mdadm=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_kmod-md-raid456=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_kmod-md-linear=y

# 插件：Argon 主题设置
CONFIG_DEFAULT_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 插件：网络向导
CONFIG_DEFAULT_luci-app-quickstart=y
CONFIG_PACKAGE_luci-app-quickstart=y

# 插件：易有云文件管理器
CONFIG_DEFAULT_luci-app-linkease=y
CONFIG_PACKAGE_luci-app-linkease=y

# 插件：OpenClash
CONFIG_DEFAULT_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-openclash=y

# 插件：统一文件共享
CONFIG_DEFAULT_luci-app-unishare=y
CONFIG_PACKAGE_luci-app-unishare=y

# 插件：NFS 管理
CONFIG_DEFAULT_luci-app-nfs=y
CONFIG_PACKAGE_luci-app-nfs=y

# 插件：RAID 管理
CONFIG_DEFAULT_kmod-dm-raid=y
CONFIG_PACKAGE_kmod-dm-raid=y

# 插件：S.M.A.R.T.
CONFIG_DEFAULT_luci-app-smartd=y
CONFIG_PACKAGE_luci-app-smartd=y

# 插件：挂载网络共享
CONFIG_DEFAULT_luci-app-cifs-mount=y
CONFIG_PACKAGE_luci-app-cifs-mount=y

# 插件:终端
CONFIG_PACKAGE_luci-app-ttyd=y
# 启用 ttyd 服务的相关依赖
CONFIG_PACKAGE_ttyd=y               # ttyd 服务本体
CONFIG_PACKAGE_luci-lib-jsonc=y      # luci 的 JSON 解析库（用于 UI）
CONFIG_PACKAGE_libjson-c=y          # JSON 解析库（ttyd 可能依赖）
CONFIG_PACKAGE_libwebsockets=y      # WebSocket 支持库（ttyd 通信）
CONFIG_PACKAGE_libncurses=y         # Ncurses 库（终端模拟，可选）

# --------------------------------------------------
# 1. CPU 调节插件
# --------------------------------------------------
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_cpufreq-utils=y

# --------------------------------------------------
# 2. IPK 镜像服务器插件
# --------------------------------------------------
CONFIG_PACKAGE_luci-app-ipkg-mirror=y
CONFIG_PACKAGE_uhttpd=y

# --------------------------------------------------
# 3. Samba 文件共享插件
# --------------------------------------------------
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y

# --------------------------------------------------
# 4. 启动管理插件
# --------------------------------------------------
CONFIG_PACKAGE_luci-app-startup=y

# --------------------------------------------------
# 5. 沙箱插件
# --------------------------------------------------
CONFIG_PACKAGE_luci-app-sandbox=y

# --------------------------------------------------
# 常用网卡驱动
# --------------------------------------------------

# 网卡驱动（无线）
CONFIG_PACKAGE_kmod-ath9k=y      # Atheros 9k 无线驱动
CONFIG_PACKAGE_kmod-ath10k=y     # Atheros 10k 无线驱动
CONFIG_PACKAGE_kmod-b43=y        # Broadcom B43 无线驱动
CONFIG_PACKAGE_kmod-brcmsmac=y   # Broadcom Brcm 无线驱动
CONFIG_PACKAGE_kmod-iwlwifi=y    # Intel 无线驱动
CONFIG_PACKAGE_kmod-mwifiex=y    # Marvell Wi-Fi 驱动
CONFIG_PACKAGE_kmod-rtl8188eu=y  # Realtek 8188 USB 无线驱动
CONFIG_PACKAGE_kmod-rtl8192cu=y  # Realtek 8192 USB 无线驱动
CONFIG_PACKAGE_kmod-rtl8821cu=y  # Realtek 8821 USB 无线驱动
CONFIG_PACKAGE_kmod-rt2800usb=y  # Ralink 2800 USB 无线驱动
CONFIG_PACKAGE_kmod-rt5390=y     # Ralink 5390 系列无线驱动

# 网卡驱动（有线）
CONFIG_PACKAGE_kmod-rtl8139=y    # Realtek 8139 网卡驱动
CONFIG_PACKAGE_kmod-eth-rtl8169=y # Realtek 8169 千兆网卡驱动
CONFIG_PACKAGE_kmod-igb=y         # Intel 1GB 网卡驱动
CONFIG_PACKAGE_kmod-e1000e=y      # Intel 1G/10G 网卡驱动
CONFIG_PACKAGE_kmod-tun=y         # TAP/虚拟网卡支持
CONFIG_PACKAGE_kmod-veth=y        # Veth 虚拟网卡支持
CONFIG_PACKAGE_kmod-xgbe=y        # Xilinx 10G 网卡驱动

# 虚拟化网络适配器驱动
CONFIG_PACKAGE_kmod-virtio-net=y  # Virtio 网络适配器驱动
CONFIG_PACKAGE_kmod-virtio-pci=y  # Virtio PCIe 适配器驱动

# --------------------------------------------------
# 常用 USB 驱动
# --------------------------------------------------

# USB 控制器及存储
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ehci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-hid=y

# USB 无线网卡驱动
CONFIG_PACKAGE_kmod-rtl8188eu=y
CONFIG_PACKAGE_kmod-rtl8192cu=y
CONFIG_PACKAGE_kmod-rt2800usb=y

# USB 打印机、音频及其他支持
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_kmod-usb-audio=y

# --------------------------------------------------
# 常用 PCIe 设备驱动
# --------------------------------------------------

# PCIe 网卡驱动
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-mlx4_core=y
CONFIG_PACKAGE_kmod-net-mlx5-core=y

# PCIe 存储设备驱动
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-ata-ahci=y
CONFIG_PACKAGE_kmod-usb-storage=y

# PCIe 无线网卡驱动
CONFIG_PACKAGE_kmod-ath9k-pci=y
CONFIG_PACKAGE_kmod-ath10k-pci=y
CONFIG_PACKAGE_kmod-iwlwifi-pci=y

# 其他 PCIe 设备驱动
CONFIG_PACKAGE_kmod-pcie-rtl8169=y
CONFIG_PACKAGE_kmod-pcie-rtl8139=y
CONFIG_PACKAGE_kmod-tun-pci=y

# --------------------------------------------------
# 其他驱动
# --------------------------------------------------
CONFIG_PACKAGE_kmod-nvidia=y        # NVIDIA 显卡驱动（如有需求）
CONFIG_PACKAGE_kmod-fb=y
CONFIG_PACKAGE_kmod-vga16fb=y
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-md5=y
CONFIG_PACKAGE_kmod-crypto-sha256=y

# --------------------------------------------------
# 系统文件系统及磁盘管理驱动
# --------------------------------------------------
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-xfs=y
CONFIG_PACKAGE_kmod-fs-fuse=y

# --------------------------------------------------
# USB 设备驱动（键盘、鼠标、摄像头等）
# --------------------------------------------------
CONFIG_PACKAGE_kmod-usb-hid=y
CONFIG_PACKAGE_kmod-video-usb-v2=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-pl2303=y

# --------------------------------------------------
# 其他常用硬件驱动
# --------------------------------------------------
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-asix=y

# --------------------------------------------------
# 调试工具（仅供开发使用）
# --------------------------------------------------
CONFIG_PACKAGE_kmod-usb-debug=y
CONFIG_PACKAGE_kmod-phy-bcm-ns2=y

# --------------------------------------------------
# 文件系统及镜像设置（适用于斐讯 N1，移除 x86 专用 ISO/VHDX 设置）
# --------------------------------------------------
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_RESERVED_PCT=0
CONFIG_TARGET_EXT4_BLOCKSIZE_4K=y
CONFIG_TARGET_EXT4_BLOCKSIZE=4096
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_IMAGES_GZIP=y

# --------------------------------------------------
# 签名与安全性
# --------------------------------------------------
CONFIG_SIGNED_PACKAGES=y
CONFIG_SIGNATURE_CHECK=y
CONFIG_DOWNLOAD_CHECK_CERTIFICATE=y

# --------------------------------------------------
# 内核功能与调试（保留核心项）
# --------------------------------------------------
CONFIG_KERNEL_PRINTK=y
CONFIG_KERNEL_SWAP=y
CONFIG_KERNEL_DEBUG_FS=y
CONFIG_KERNEL_DEBUG_KERNEL=y
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_REDUCED=y
CONFIG_KERNEL_FRAME_WARN=2048
CONFIG_KERNEL_AIO=y
CONFIG_KERNEL_IO_URING=y
CONFIG_KERNEL_FHANDLE=y

# --------------------------------------------------
# Cgroup、命名空间及资源管理
# --------------------------------------------------
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_FREEZER=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_HUGETLB=y
CONFIG_KERNEL_CGROUP_PIDS=y
CONFIG_KERNEL_CPUSETS=y
CONFIG_KERNEL_CGROUP_CPUACCT=y
CONFIG_KERNEL_RESOURCE_COUNTERS=y
CONFIG_KERNEL_MEMCG=y
CONFIG_KERNEL_MEMCG_SWAP=y
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_UTS_NS=y
CONFIG_KERNEL_IPC_NS=y
CONFIG_KERNEL_USER_NS=y
CONFIG_KERNEL_PID_NS=y
CONFIG_KERNEL_NET_NS=y

# --------------------------------------------------
# IPv6 支持
# --------------------------------------------------
CONFIG_KERNEL_IPV6=y
CONFIG_KERNEL_IPV6_MULTIPLE_TABLES=y
CONFIG_KERNEL_IPV6_MROUTE=y

# --------------------------------------------------
# 安全加固选项
# --------------------------------------------------
CONFIG_SECCOMP=y
CONFIG_KERNEL_CC_STACKPROTECTOR_REGULAR=y
CONFIG_PKG_CC_STACKPROTECTOR_REGULAR=y
CONFIG_PKG_FORTIFY_SOURCE_1=y
CONFIG_PKG_RELRO_FULL=y

# --------------------------------------------------
# 编译工具链与优化设置
# --------------------------------------------------
CONFIG_MOLD=y
CONFIG_GDB=y
CONFIG_BINUTILS_VERSION_2_40=y
CONFIG_BINUTILS_VERSION="2.40"
CONFIG_GCC_VERSION="13.3.0"
CONFIG_LIBC="musl"
CONFIG_TARGET_SUFFIX="musl"
CONFIG_EXTRA_OPTIMIZATION="-fno-caller
